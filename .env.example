# Pick ONE provider and set TOP30_PROVIDER (or leave it on "auto" to
# auto-detect from whichever key is present).
TOP30_PROVIDER=auto

# --- Option 1: Google Gemini (free tier in Google AI Studio) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# --- Option 2: OpenRouter (one key, many models) ---
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Append ":online" to any model to enable live web search.
OPENROUTER_MODEL=google/gemini-2.5-flash:online
# Optional: shown on your OpenRouter dashboard.
OPENROUTER_SITE_URL=https://game-of-30.vercel.app

# --- Option 3: OpenAI ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
