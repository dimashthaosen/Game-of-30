# Recommended free-tier setup: create this in Google AI Studio.
GEMINI_API_KEY=your-gemini-api-key

# Optional. Defaults to Gemini because its Developer API has a free tier.
TOP30_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# Optional fallback if you prefer OpenAI instead.
OPENAI_API_KEY=sk-your-api-key
OPENAI_MODEL=gpt-5.4-mini
